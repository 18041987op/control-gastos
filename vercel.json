{
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "duplex.osmanventures.io" }],
      "destination": "/duplex/index.html"
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "duplex.osmanventures.io" }],
      "destination": "/duplex/:path+"
    }
  ]
}
